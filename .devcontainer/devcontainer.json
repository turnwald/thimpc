{
  "name": "THI MPC Course",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "forwardPorts": [8888],
  "postStartCommand": "jupyter lab --ip=0.0.0.0 --port=8888 --no-browser --allow-root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  }
}
